.DS_Store
ante/
__pycache__/
*.pyc

# Generated figures: regenerate with `make figures` (not versioned -- avoids binary git bloat)
figures/
# ...pero las figuras del proyecto LaTeX SÍ se versionan: Overleaf las compila desde GitHub.
!reports/latex/Figures/
!reports/latex/Figures/**
reports/latex/Figures/.DS_Store
# Figuras del paper MICAI (PDF vectoriales; Overleaf las importa de GitHub igual que el deliverable)
!reports/paper_micai/Figures/
!reports/paper_micai/Figures/**

# Tooling caches / coverage artifacts
.coverage
.coverage.*
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/

# Packaging build artifacts (pip install -e .) — must stay out so the daily
# Action's `git add -A` never commits them.
*.egg-info/
build/
dist/

# Internal AI/context notes — not part of the public deliverable.
CLAUDE.md

# Microsoft Office temp/lock files
~$*

# Regenerated star-schema DB and typed export (open CSV is the versioned source;
# rebuild with `make db`). Kept out of git to avoid binary bloat.
data/processed/*.duckdb
data/processed/*.parquet

# Raw HTML snapshots: master copy lives in S3 (cold backup), not git.
data/snapshots/

# Modeling artifacts — regenerables con `make compare` / `make report` / `make eda`
reports/*.log
reports/eval/model_comparison.csv
reports/eval/results_table.tex
reports/figures/eda_*.png
reports/figures/results_*.png
# Resultados de los barridos profundos/HPO/PI — regenerables con los scripts run_*.py
# E4: global_*/deep_pi_*/crps_*/tuned_params/tuning_confirmation/holdout_forecasts_*/
# model_comparison_*/experiment_runs.jsonl estaban gitignored PERO trackeados (gitignore
# no aplica a tracked): son la PROCEDENCIA de cifras publicadas y los consumen
# champion/ensemble/figuras/tests → decisión: SE VERSIONAN (patrones retirados, ~1.8 MB).
reports/eval/neuralforecast_forecasts.csv
# Storage sqlite del HPO Optuna (AK4) — binario regenerable; la procedencia legible
# vive en reports/campaign/hpo_trials_*.csv (versionados)
reports/eval/optuna.db
ante_nf/

# Efecto secundario del logger de Lightning (modelos torch de darts) — regenerable
lightning_logs/

# Artefactos de build LaTeX (Overleaf no los versiona; parses locales sí los generan)
reports/latex/*.pdf
reports/latex/*.aux
reports/latex/*.log
reports/latex/*.out
reports/latex/*.toc
reports/latex/*.synctex.gz

# Reportes de auditoría regenerables — mega_audit SÍ se versiona (fuente RAG del VisaBot
# y solo cambia cuando cambian los datos); los demás siguen fuera.
reports/governance/mlops_audit_report.md
reports/governance/solid_clean_audit_report.md

# MLflow tracking (local file store) + staging — regenerable, no versionar en git
mlruns/
mlruns_staging/
mlruns_staging.quarantine_*/
mlflow.db
mlartifacts/
# Manifiesto por-corrida de la campaña (identidad; efímero, no versionar)
reports/campaign/campaign_manifest.json
# Modelos entrenados -> versionados con DVC, no git
models/
/models

# campaign_pool_*.csv SE VERSIONAN (C1): son la procedencia de las cifras canónicas
# (ets/theta hold_mase) y build_key_facts.py los lee en el runner limpio del Action.
# Venvs efímeros de experimentos con deps en conflicto (TabPFN/TimesFM) — recrear
# solo si se re-corre improve_tabpfn/improve_timesfm (ver sus docstrings).
ante_tab/
ante_tfm/

# AQ campaign logs (transient; provenance lives in reports/campaign/ CSVs)
reports/campaign_aq.log
reports/campaign_aq_logs/

# Ad-hoc backup files (p. ej. optuna.db.*.bak antes de una re-campaña) — nunca se trackean.
*.bak

# P0R.3: receipt de supply chain (artefacto runtime del cron/audit, regenerable)
reports/governance/supply_chain_receipt.json
.vp_envs/
.dvc/site-cache/

# B89: lock de exclusión de merge_campaign_pools (artefacto runtime, jamás se trackea)
reports/campaign/.merge.lock
# B117 (R9.2R9): cuarentena de temporales/respaldos del merge (GC diferido a P2b; runtime, nunca trackear)
reports/campaign/.merge-quarantine/
reports/eval/.merge-quarantine/
