.DS_Store
ante/
__pycache__/
*.pyc

# Generated figures: regenerate with `make figures` (not versioned -- avoids binary git bloat)
figures/
# ...pero las figuras del proyecto LaTeX SÍ se versionan: Overleaf las compila desde GitHub.
!reports/latex/Figures/
!reports/latex/Figures/**
reports/latex/Figures/.DS_Store

# Tooling caches / coverage artifacts
.coverage
.coverage.*
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/

# Packaging build artifacts (pip install -e .) — must stay out so the daily
# Action's `git add -A` never commits them.
*.egg-info/
build/
dist/

# Internal AI/context notes — not part of the public deliverable.
CLAUDE.md

# Microsoft Office temp/lock files
~$*

# Materiales de referencia del curso (PDFs/DOCX de terceros, ejemplos) — no es el entregable.
docs/ProyectoInnovaTecI/

# Notas internas de investigación (revisiones de literatura, análisis de brechas) — no
# forman parte del entregable público; `epiforecast_gap_analysis` además es contexto interno.
reports/epiforecast_gap_analysis.md
reports/litreview_*.md

# Regenerated star-schema DB and typed export (open CSV is the versioned source;
# rebuild with `make db`). Kept out of git to avoid binary bloat.
data/processed/*.duckdb
data/processed/*.parquet

# Raw HTML snapshots: master copy lives in S3 (cold backup), not git.
data/snapshots/

# Modeling artifacts — regenerables con `make compare` / `make report` / `make eda`
reports/model_comparison.csv
reports/results_table.tex
reports/experiment_runs.jsonl
reports/figures/eda_*.png
reports/figures/results_*.png
reports/model_comparison_*.csv
# Resultados de los barridos profundos/HPO/PI — regenerables con los scripts run_*.py
reports/global_*.csv
reports/deep_pi_*.csv
reports/crps_*.csv
reports/tuned_params.json
reports/tuning_confirmation.csv
reports/holdout_forecasts_*.csv
reports/neuralforecast_forecasts.csv
ante_nf/

# Efecto secundario del logger de Lightning (modelos torch de darts) — regenerable
lightning_logs/

# Artefactos de build LaTeX (Overleaf no los versiona; parses locales sí los generan)
reports/latex/*.aux
reports/latex/*.log
reports/latex/*.out
reports/latex/*.toc
reports/latex/*.synctex.gz

# Reportes de auditoría regenerables — no versionar (causan árbol sucio)
reports/*_audit_report.md
